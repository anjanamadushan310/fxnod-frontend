# ============================================================================
# FXNod frontend — public runtime config (NEXT_PUBLIC_* only).
#
# These are the EXACT keys to add in the Vercel dashboard:
#   Project → Settings → Environment Variables
#
# Only NEXT_PUBLIC_* vars reach the browser. Never put secrets here — there
# are none for the frontend (the access token is issued at runtime, the
# refresh token is an httpOnly cookie the JS never sees).
# ============================================================================

# Backend REST base — the VPS API domain fronted by Caddy. No trailing slash.
#   Production : https://api.fxnod.com
#   Local dev  : http://localhost            (NGINX gateway on :80)
NEXT_PUBLIC_API_URL=https://api.fxnod.com

# Backend WebSocket base — same host, ws(s) scheme. No trailing slash.
#   Production : wss://api.fxnod.com
#   Local dev  : ws://localhost
NEXT_PUBLIC_WS_URL=wss://api.fxnod.com
